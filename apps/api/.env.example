# Neon: Project → Connection string (pooled or direct)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Shared secret between mobile app and API (use a long random string)
SYNC_API_SECRET=change-me-to-a-long-random-secret

# Logical space for a couple (same value on both partners' devices)
COUPLE_ID=default

PORT=3001
